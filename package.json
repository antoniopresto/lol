{
  "name": "lol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Raycast clone for internal use.",
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniopresto/lol"
  },
  "author": "@antoniopresto <antoniopresto@gmail.com>",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "coverage": "vitest --coverage",
    "check": "run-s check:*",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint src --fix",
    "check:format": "prettier --write .",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@belt/prettier-plugin": "latest",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
